@model EtkinlikSeminerKayit.Application.DTOs.CreateReservationDto

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4>Yeni Rezervasyon Oluştur</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" id="reservationForm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Uygulama/Seminer Salonu</label>
                        <select asp-for="ResourceId" class="form-select" required>
                            <option value="">Salon Seçiniz...</option>
                            @foreach (var item in ViewBag.Resources)
                            {
                                <option value="@item.Id">@item.Name (Kapasite: @item.Capacity)</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Etkinlik Türü</label>
                        <select asp-for="EventTypeId" id="EventTypeId" class="form-select" required>
                            <option value="">Seçiniz...</option>
                            @foreach (var item in ViewBag.EventTypes)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Başlangıç Zamanı</label>
                        <input asp-for="StartTime" type="datetime-local" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Bitiş Zamanı</label>
                        <input asp-for="EndTime" type="datetime-local" class="form-control" required />
                    </div>
                </div>

                <hr />
                <div id="dynamicFieldsContainer" class="row">
                    <div class="col-12">
                        <p class="text-muted italic">Lütfen yukarıdan bir etkinlik türü seçin...</p>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success w-100">Kaydı Tamamla</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/reservationCreate.js"></script>
}
